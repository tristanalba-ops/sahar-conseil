# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars-randomstring

# Anthropic
NEXT_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...

# GCP Cloud Functions
NEXT_PUBLIC_GCP_SCORE_FUNCTION_URL=https://region-project.cloudfunctions.net/score
NEXT_PUBLIC_GCP_STATS_FUNCTION_URL=https://region-project.cloudfunctions.net/stats
NEXT_PUBLIC_GCP_FORECAST_FUNCTION_URL=https://region-project.cloudfunctions.net/forecast

# BAN API (public, no key needed)
NEXT_PUBLIC_BAN_API_URL=https://api-adresse.data.gouv.fr

# Optional: Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
